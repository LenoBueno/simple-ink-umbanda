{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "outDir": "./dist",
    "esModuleInterop": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "noImplicitAny": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "allowJs": false,
    "noUnusedLocals": false,
    "strictNullChecks": false
  },
  "include": [
    "src/**/*.tsx",
    "src/**/*.ts"
  ],
  "references": []
}